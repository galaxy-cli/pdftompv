#!/bin/bash
#      _ __ | |/ _| |_ ___  _ __ ___  _ ____   __
# | '_ \ / _` | |_| __/ _ \| '_ ` _ \| '_ \ \ / /
# | |_) | (_| |  _| || (_) | | | | | | |_) \ V /
# | .__/ \__,_|_|  \__\___/|_| |_| |_| .__/ \_/
# |_|                                |_|
#
# pdftompv - PDF to MP3 converter using pdftotext, edge-tts (Neural AI), and MPV
#
# Project: https://github.com

VERSION="1.9.6"
PROGNAME=$(basename "$0")
SELECTED_VOICE="en-US-AriaNeural"
declare -a WORK_DIRS=()

cleanup() {
    [ -n "$EVINCE_PID" ] && kill "$EVINCE_PID" 2>/dev/null
    for dir in "${WORK_DIRS[@]}"; do [ -d "$dir" ] && rm -rf "$dir"; done
}
trap cleanup EXIT INT TERM

error_msg() { echo "${PROGNAME}: ${2:+$2: }$1" >&2; }

check_dep() {
    local cmd="$1" pkg="$2"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "${PROGNAME}: dependency '${cmd}' (${pkg}) is missing." >&2
        read -p "Install via apt? [y/N] " ans < /dev/tty
        [[ "$ans" =~ ^[Yy] ]] && sudo apt-get update && sudo apt-get install -y "$pkg" || exit 1
    fi
}

# Verify Core Dependencies
check_dep "pdftotext" "poppler-utils"; check_dep "wget" "wget"; check_dep "mpv" "mpv"
check_dep "evince" "evince"; check_dep "pipx" "pipx"

if ! command -v edge-tts >/dev/null 2>&1; then
    pipx ensurepath --quiet && pipx install edge-tts && export PATH="$PATH:$HOME/.local/bin"
fi

get_clipboard() {
    for cmd in xclip xsel wl-paste pbpaste; do
        if command -v "$cmd" >/dev/null 2>&1; then
            case "$cmd" in
                xclip) xclip -selection clipboard -o 2>/dev/null ;;
                xsel)  xsel --clipboard --output 2>/dev/null ;;
                *)     "$cmd" 2>/dev/null ;;
            esac | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' && return 0
        fi
    done
    error_msg "No clipboard utility found."; return 1
}

print_usage() {
    cat <<EOF
Usage: ${PROGNAME} [OPTION]... [URL | TARGET]
Options:
  --pdf              Convert PDF to MP3
  --open             Launch file based on extension (.pdf, .mp3, or .*)
  --voice            Set neural voice
  --url [LINK]       Download PDF (reads clipboard if LINK is omitted)
  --version / --help Output info and exit
EOF
}

convert_pdf_to_mp3() {
    local pdf="$1" mp3_final="${1%.*}.mp3" start_time=$SECONDS
    local work_dir=$(mktemp -d -t pdftompv-XXXXXXXX) && WORK_DIRS+=("$work_dir")
    local txt_file="$work_dir/extracted.txt"

    echo "${PROGNAME}: extracting text..." >&2
    pdftotext -raw "$pdf" "$txt_file" 2>/dev/null
    if [ ! -s "$txt_file" ]; then error_msg "Extraction failed or file empty" "$pdf"; exit 1; fi

    sed ':a;N;$!ba;s/\n/ /g' "$txt_file" | sed 's/\.\.\././g' > "$work_dir/clean.txt"
    split -d -a 4 -l 300 "$work_dir/clean.txt" "$work_dir/chunk_"
    
    local chunks=("$work_dir"/chunk_[0-9]*) total=${#chunks[@]}
    echo "${PROGNAME}: rendering audiobook segments via [${SELECTED_VOICE}] in parallel..." >&2

    # Scale parallel jobs up to CPU core count (throttled to limit API rate spikes)
    local max_jobs=$(nproc 2>/dev/null || echo 4)

    for chunk in "${chunks[@]}"; do
        [ -e "$chunk" ] || continue
        
        (
            for attempt in {1..3}; do
                if edge-tts --file "$chunk" --write-media "${chunk}.mp3" --rate=+25% --voice "$SELECTED_VOICE" >/dev/null 2>&1; then
                    exit 0
                fi
                sleep 2
            done
            error_msg "Chunk processing failure after 3 attempts" "$chunk"
            exit 1
        ) &

        # Keep job counts within thread pool bounds
        while [ $(jobs -r | wc -l) -ge "$max_jobs" ]; do
            sleep 0.2
        done
    done

    # --- LIVE PROCESSING TIMER LOOP ---
    local elapsed=0
    while true; do
        local running_jobs=$(jobs -r | wc -l)
        [ "$running_jobs" -eq 0 ] && break

        local completed_files=$(find "$work_dir" -name "chunk_*.mp3" -type f | wc -l)
        echo -ne "${PROGNAME}: Processing... [Time elapsed: ${elapsed}s] [Chunks complete: ${completed_files}/${total}]\r" >&2
        
        sleep 1
        ((elapsed++))
    done
    echo "" >&2 
    
    # Verify all compiled chunks successfully generated matching media pieces
    for chunk in "${chunks[@]}"; do
        if [ ! -s "${chunk}.mp3" ]; then
            error_msg "Audio synthesis step incomplete due to job execution tracking faults."
            exit 1
        fi
    done

    echo "${PROGNAME}: stitching processed binary audio tracks..." >&2
    cat "$work_dir"/chunk_[0-9]*.mp3 > "$mp3_final"
    echo "${PROGNAME}: complete -> ${mp3_final}" >&2
}

# --- PARSE COMMAND LINE ARGUMENTS ---
[ $# -eq 0 ] && print_usage && exit 2
do_pdf=false; do_open=false; use_url=false; voice_test=false; input=""

while [ $# -gt 0 ]; do
    case "$1" in
        --pdf)  do_pdf=true; shift ;;
        --open) do_open=true; shift ;;
        --version) echo "${PROGNAME} ${VERSION}"; exit 0 ;;
        --help)    print_usage; exit 0 ;;
        --voice)
            if [ -z "$2" ]; then
                echo "Opening Azure voice gallery: https://json2video.com/ai-voices/azure/voices/" >&2; exit 0
            fi
            SELECTED_VOICE="$2"; voice_test=true; shift 2 ;;
        --url)
            use_url=true
            if [ -n "$2" ] && [[ "$2" != -* ]]; then input="$2"; shift 2; else input=$(get_clipboard) || exit 1; shift 1; fi ;;
        -*)     error_msg "Unrecognized option '$1'"; exit 2 ;;
        *)      input="$1"; shift ;;
    esac
done

# Short-circuit for solo voice testing
if [ "$voice_test" = true ] && [ -z "$input" ] && [ "$do_pdf" = false ] && [ "$do_open" = false ]; then
    work_dir=$(mktemp -d -t pdftompv-XXXXXXXX) && WORK_DIRS+=("$work_dir")
    edge-tts --text "Hello! Previewing voice profile." --write-media "$work_dir/t.mp3" --rate=+25% --voice "$SELECTED_VOICE" >/dev/null 2>&1
    mpv "$work_dir/t.mp3"; exit 0
fi

[ -z "$input" ] && { error_msg "Missing target file or URL"; exit 2; }
[[ "$input" =~ ^https?:// ]] && use_url=true

# Handle URL Downloading
if [ "$use_url" = true ]; then
    clean_url="${input%%\?*}"
    filename=$(basename "$clean_url")
    filename=$(python3 -c "import urllib.parse; print(urllib.parse.unquote('''$filename'''))")
    [[ "$filename" != *.pdf ]] && filename="${filename%.*}.pdf"
    [ -z "$filename" ] && filename="downloaded_document.pdf"
    wget -q --show-progress -O "$filename" "$input" || exit 1
    input="$filename"
fi

# Standardize File Extensions & Track Suffix Intent
base="${input%.*}"
if [ "$use_url" = true ] || { [[ "$input" == *.* ]] && [[ "$input" != *.pdf && "$input" != *.mp3 ]]; }; then
    mode="wildcard"
elif [[ "$input" == *.pdf ]]; then
    mode="pdf"
elif [[ "$input" == *.mp3 ]]; then
    mode="mp3"
else
    error_msg "Target must end in .pdf, .mp3, or .*"; exit 2
fi

# Execute Operational Chain
[ "$do_pdf" = true ] && convert_pdf_to_mp3 "${base}.pdf"

if [ "$do_open" = true ]; then
    case "$mode" in
        pdf)      [ -f "${base}.pdf" ] && evince "${base}.pdf" >/dev/null 2>&1 || { error_msg "PDF missing" "${base}.pdf"; exit 1; } ;;
        mp3)      [ -f "${base}.mp3" ] && mpv "${base}.mp3" || { error_msg "MP3 missing" "${base}.mp3"; exit 1; } ;;
        wildcard) [ -f "${base}.pdf" ] && (evince "${base}.pdf" >/dev/null 2>&1 & EVINCE_PID=$!)
                  [ -f "${base}.mp3" ] && mpv "${base}.mp3" || { error_msg "MP3 missing" "${base}.mp3"; exit 1; } ;;
    esac
fi