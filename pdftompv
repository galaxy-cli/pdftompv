#!/bin/bash
#      _ __ | |/ _| |_ ___  _ __ ___  _ ____   __
# | '_ \ / _` | |_| __/ _ \| '_ ` _ \| '_ \ \ / /
# | |_) | (_| |  _| || (_) | | | | | | |_) \ V /
# | .__/ \__,_|_|  \__\___/|_| |_| |_| .__/ \_/
# |_|                                |_|
#
# pdftompv - PDF to MP3 converter using pdftotext, edge-tts (Neural AI), and MPV
# Upgraded for 500+ page stability and high-quality AI voices.
#
# Project: https://github.com/galaxy-cli/pdftompv

trap "echo -e '\nExiting...'; exit" INT TERM

# --- DEPENDENCY CHECK ---
check_dep() {
    local cmd="$1"
    local pkg="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo "'$cmd' (from $pkg) is not installed"
        read -p "Install it now? [y/N] " answer
        if [[ "$answer" =~ ^[Yy](es)?$ ]]; then
            sudo apt-get update && sudo apt-get install -y "$pkg"
        else
            exit 1
        fi
    fi
}

check_edge_tts() {
    if ! command -v edge-tts &>/dev/null; then
        echo "'edge-tts' not found. Installing via pipx..."
        check_dep "pipx" "pipx"
        pipx ensurepath --quiet
        pipx install edge-tts
        export PATH="$PATH:$HOME/.local/bin"
    fi
}

check_dep "pdftotext" "poppler-utils"; check_dep "wget" "wget"
check_dep "mpv" "mpv"; check_dep "evince" "evince"; check_dep "pv" "pv"
check_edge_tts

# --- USAGE ---
print_usage() {
  cat <<EOF
DESCRIPTION
  Download, convert, and listen to PDFs as high-quality AI audiobooks.

USAGE
  pdftompv [OPTION] [URL | PDF]

OPTION
  --help      Show this help message
  --pdf       Convert PDF file to MP3
  --open      Open PDF file and play MP3
  --url       Download PDF from URL before processing
EOF
}

# --- FUNCTIONS ---
convert_pdf_to_mp3() {
    local pdf="$1"
    local mp3_final="${pdf%.pdf}.mp3"
    local txt_file="${pdf%.pdf}.txt"
    local chunk_prefix="temp_chunk_$(date +%s)"
    
    # Specific cleanup function for temporary conversion files only
    cleanup_chunks() {
        echo -e "\nCleaning up temporary chunks..."
        rm -f "${chunk_prefix}"_* "$txt_file"
    }
    # Trap ensures cleanup even if conversion is cancelled mid-way
    trap cleanup_chunks EXIT INT TERM

    local start_time=$SECONDS
    echo "Extracting text..." >&2
    pdftotext -raw "$pdf" "$txt_file" 2>/dev/null
    
    sed -i ':a;N;$!ba;s/\n/ /g' "$txt_file"
    sed -i 's/\.\.\././g' "$txt_file"

    [[ ! -s "$txt_file" ]] && { echo "ERROR - Extraction failed." >&2; exit 1; }

    # Split into manageable sizes to prevent API timeouts
    split -b 25000 "$txt_file" "${chunk_prefix}_"
    local chunks=("${chunk_prefix}"_*)
    local total=${#chunks[@]}
    local count=1

    echo "Converting to MP3 (Neural AI)..." >&2
    for chunk in "${chunks[@]}"; do
        echo -n "Processing chunk [$count/$total]... " >&2
        echo
        
        if ! edge-tts --file "$chunk" --write-media "${chunk}.mp3" --rate=+25% --voice en-US-AriaNeural &>/dev/null; then
            echo "Failed." >&2
            exit 1
        fi

        echo -n 
        ((count++))
    done

    echo "Stitching chunks together..." >&2
    cat "${chunk_prefix}"_*.mp3 > "$mp3_final"

    local total_time=$(( SECONDS - start_time ))
    echo -e "\nSuccess: $mp3_final created (${total_time%60} sec)"
    
    # Clean up and remove trap so it doesn't fire when the script officially exits
    cleanup_chunks
    trap - EXIT INT TERM
}

open_file() {
    local pdf="$1"
    local mp3="${pdf%.pdf}.mp3"
    
    # Open PDF in background if it exists
    [[ -f "$pdf" ]] && { evince "$pdf" &>/dev/null & }
    
    # Play MP3 in foreground so script waits for it to finish
    if [[ -f "$mp3" ]]; then
        echo "Playing audio: $mp3"
        mpv "$mp3"
    else
        echo "Error: Audio file '$mp3' not found."
    fi
}

download_pdf() {
    local url="$1"
    local raw_filename=$(basename "$url")
    local filename=$(python3 -c "import urllib.parse; print(urllib.parse.unquote('$raw_filename'))")
    wget -q --show-progress -O "$filename" "$url" || exit 1
    echo "$filename"
}

# --- MAIN LOGIC ---
[[ $# -eq 0 ]] && { print_usage; exit 1; }

input=""; use_url=false; do_pdf=false; do_open=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pdf)  do_pdf=true ;;
        --open) do_open=true ;;
        --url)  use_url=true ;;
        --help) print_usage; exit 0 ;;
        *)      input="$1" ;;
    esac
    shift
done

$use_url && input=$(download_pdf "$input")

# Sequence: Convert first, then open
$do_pdf && convert_pdf_to_mp3 "$input"
$do_open && open_file "$input"