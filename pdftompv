#!/bin/bash
#        _ __ | |/ _| |_ ___  _ __ ___  _ ____   __
#   | '_ \ / _` | |_| __/ _ \| '_ ` _ \| '_ \ \ / /
#   | |_) | (_| |  _| || (_) | | | | | | |_) \ V /
#   | .__/ \__,_|_|  \__\___/|_| |_| |_| .__/ \_/
#   |_|                                |_|
#
# pdftompv - PDF to MP3 converter utility using pdftotext, text2wave (Festival), LAME, and MPV
#
# Project: https://github.com/galaxy-cli/check

# --- DEPENDENCY CHECK ---
check_dep() {
    local cmd="$1"
    local pkg="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo "'$cmd' (from $pkg) is not installed"
        read -p "Install it now? [y/N] " answer
        if [[ "$answer" =~ ^[Yy](es)?$ ]]; then
            sudo apt-get update && sudo apt-get install -y "$pkg"
        else
            exit 1
        fi
    fi
}

check_dep "pdftotext" "poppler-utils"; check_dep "wget" "wget"
check_dep "festival" "festival"; check_dep "lame" "lame"
check_dep "mpv" "mpv"; check_dep "evince" "evince"; check_dep "pv" "pv"

# --- USAGE ---
print_usage() {
  cat <<EOF
DESCRIPTION
  Download, convert, and listen to PDFs as audiobooks

USAGE
  pdftompv [OPTION] [URL | PDF]

OPTION
  --help      Show this help message
  --pdf       Convert PDF file to MP3
  --open      Open PDF file and play MP3
  --url       Download PDF from URL before processing

EXAMPLES
  pdftompv --pdf document.pdf                           Convers PDF file to MP3
  pdftompv --url https://www.example.com/document.pdf   Dowloads PDF from URL 
  pdftompv --open document.mp3                          Open PDF file and play MP3
EOF
}

# --- FUNCTIONS ---
convert_pdf_to_mp3() {
    local pdf="$1"
    local mp3="${pdf%.pdf}.mp3"

    local text_content=$(pdftotext -raw "$pdf" - 2>/dev/null)    
    local char_count=${#text_content}
    
    [[ "$char_count" -eq 0 ]] && { echo "Scanned PDF" >&2; exit 1; }

    echo "Converting to MP3..." >&2

    if echo "$text_content" | nice -n -5 \
        text2wave -eval "(Parameter.set 'Duration_Stretch 0.7)" - 2>/dev/null | \
        lame -V 9 --abr 64 --bitwidth 16 -m m - - 2>/dev/null | \
        pv -t > "$mp3"; then    
        echo -e "\a\n$mp3 created"
    else
        echo -e "\a\nConversion failed" >&2
        exit 1
    fi
}

open_file() {
    local file="$1"
    { evince "$file" || echo "ERROR - No viewer found"; } &>/dev/null &
}

download_pdf() {
    local url="$1"
    local raw_filename=$(basename "$url")
    local filename=$(python3 -c "import urllib.parse; print(urllib.parse.unquote('$raw_filename'))")

    [[ "${filename,,}" != *.pdf ]] && { echo "ERROR - Not a PDF URL" >&2; exit 1; }

    echo "Downloading PDF..." >&2
    wget -q --show-progress -O "$filename" "$url" || { echo "ERROR - Download failed" >&2; exit 1; }
    echo "$filename"
}

# --- MAIN LOGIC ---
[[ $# -eq 0 ]] && { echo "Try 'pdftompv --help' for more information"; exit 1; }

input=""
use_url=false
do_pdf=false
do_open=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pdf)  do_pdf=true ;;
        --open) do_open=true ;;
        --url)  use_url=true ;;
        --help) print_usage; exit 0 ;;
        -*)     echo "Unknown option: $1"; exit 1 ;;
        *)      input="$1" ;;
    esac
    shift
done

if $use_url; then
    input=$(download_pdf "$input") || exit 1
fi

base="${input%.*}"
pdf_file="${base}.pdf"
mp3_file="${base}.mp3"

if $do_pdf; then
    [[ -f "$pdf_file" ]] && convert_pdf_to_mp3 "$pdf_file" || { echo "ERROR - PDF not found"; exit 1; }
fi

if $do_open; then
    if [[ ! -f "$pdf_file" && ! -f "$mp3_file" ]]; then
        echo "ERROR - No files found to open for '$base'" >&2
        exit 1
    fi

    echo "Opening $base..." >&2
    
    [[ -f "$pdf_file" ]] && open_file "$pdf_file"
    
    if [[ -f "$mp3_file" ]]; then
        mpv "$mp3_file"
    fi
fi
